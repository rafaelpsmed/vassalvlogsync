# ── Servidor ────────────────────────────────────
ADDR=:8080
BASE_URL=http://localhost:8080

# ── Database ────────────────────────────────────
# sqlite (padrão) ou postgres
DATABASE_DRIVER=sqlite
# SQLite: arquivo local
DATABASE_DSN=file:./data/vassalvlogsync.db?_pragma=foreign_keys(1)
# PostgreSQL: descomente e ajuste
# DATABASE_DRIVER=postgres
# DATABASE_DSN=postgres://vassal:vassal@postgres:5432/vassalvlogsync?sslmode=disable

# ── Storage ─────────────────────────────────────
# local (padrão) ou s3
STORAGE_DRIVER=local
DATA_DIR=./data/vlogs
# S3 (Cloudflare R2, AWS S3, MinIO, Wasabi, Backblaze B2):
# STORAGE_DRIVER=s3
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=...
# S3_BUCKET=vassal-vlogs
# S3_USE_SSL=true

# ── Redis ───────────────────────────────────────
# Endereço do Redis (obrigatório p/ escala horizontal)
# REDIS_ADDR=redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ── Rate Limiting ───────────────────────────────
# memory (padrão) ou redis
RATE_LIMIT_DRIVER=memory
RATE_LIMIT_RATE=30
RATE_LIMIT_BURST=60

# ── E-mail (SMTP) ───────────────────────────────
# Opcional — se não configurado, não envia notificações
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=app@dominio.com
# SMTP_PASSWORD=xxxx
# SMTP_FROM=app@dominio.com
